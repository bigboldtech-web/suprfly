# ═══════════════════════════════════════════════
# Suprfly Production Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════════════

NODE_ENV=production
PORT=5000
APP_URL=https://app.suprfly.io
API_URL=https://api.suprfly.io
FRONTEND_URL=https://app.suprfly.io

# ─── Database ───
DATABASE_URL=postgresql://suprfly:YOUR_DB_PASSWORD@localhost:5432/suprfly

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets (generate with: openssl rand -hex 64) ───
JWT_ACCESS_SECRET=GENERATE_RANDOM_64_HEX
JWT_REFRESH_SECRET=GENERATE_RANDOM_64_HEX
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Encryption Key (32 bytes hex for AES-256-GCM) ───
ENCRYPTION_KEY=GENERATE_RANDOM_32_BYTE_HEX

# ─── AI API Keys ───
ANTHROPIC_API_KEY=sk-ant-api...
OPENAI_API_KEY=sk-...
AI_MODEL=claude-3-haiku-20240307
AI_FALLBACK_MODEL=gpt-4o-mini

# ─── Email (SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@suprfly.io
EMAIL_FROM_NAME=Suprfly

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_GROWTH_MONTHLY_PRICE_ID=price_...
STRIPE_GROWTH_YEARLY_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_YEARLY_PRICE_ID=price_...

# ─── Razorpay ───
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...

# ─── Sentry ───
SENTRY_DSN=https://...@sentry.io/...
